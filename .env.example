# Book Scraping Configuration
# Copy to .env and fill in your values

# Proxy configuration (optional)
PROXY_HOST=
PROXY_PORT=
PROXY_USER=
PROXY_PASS=

# Paid proxy service (optional — for production)
# BrightData, Oxylabs, SmartProxy, etc.
PROXY_API_KEY=
PROXY_API_URL=

# Rate limiting defaults
RATE_LIMIT_SECONDS=2.0
MAX_RETRIES=3
REQUEST_TIMEOUT=30.0

# Cache duration (seconds)
CACHE_MAX_AGE=86400

# Data export format: csv, json, sqlite, parquet
EXPORT_FORMAT=csv,json

# MCP Server
MCP_SERVER_PORT=8080
MCP_API_KEY=

# Scraper-specific config
# Shopee
SHOPEE_RATE_LIMIT=5.0
# Wongnai
WONGNAI_RATE_LIMIT=4.0
# Jobsdb
JOBSDB_RATE_LIMIT=3.0
